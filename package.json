{
  "name": "heyshahrukh007.github.io",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "validate:content": "node --experimental-strip-types scripts/validate-content.mts",
    "validate:links": "node --experimental-strip-types scripts/validate-links.mts",
    "validate": "pnpm validate:content && pnpm build && pnpm validate:links"
  },
  "dependencies": {
    "@heyshahrukh007.github.io/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@heyshahrukh007.github.io/config": "workspace:*",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.3.0"
}

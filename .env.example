# Copy to repo root as `.env.local` or `.env.dev`, or to `apps/web/.env.local`.
# Optional for local dev — builds fall back to defaults when unset.
# Set NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY in Vercel for the contact form to work in production.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_access_key_here
NEXT_PUBLIC_CONTACT_FORM_URL=https://api.web3forms.com/submit
